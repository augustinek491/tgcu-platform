functions/lib/
/build
*.tsbuildinfo
web/next-env.d.ts

# ── Firebase ──────────────────────────────────────────────────
.firebase/
firebase-debug.log*
firestore-debug.log*
database-debug.log*
ui-debug.log*
pubsub-debug.log*
