serviceAccountKey.json
**/serviceAccountKey.json
*-key.json

# ── Env / secrets (keep .env.example templates) ───────────────
.env
.env.local
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.production
**/.env.*.local
!**/.env.example

# ── Internal working docs — kept OUT of the public repo (local only) ──
platform-plan/
knowledge-base/
.claude/

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea/
