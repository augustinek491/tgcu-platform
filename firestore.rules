rules_version = '2';

// TGCU Platform — Firestore Security Rules (design/03 §5).
// North-star: ALL governed writes (money/member/price/role/audit/deals/escrow) go only
// through privileged server paths (Admin SDK bypasses Rules). Client SDK is for READS and
// Auth only. Rules are the second, independent wall: deny-by-default + org-scoping +
// immutability. RBAC via Auth custom claims (FR-ADM-12); fine gating via entitlements/{uid}.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function hasRole(r) {
      return signedIn() && request.auth.token.role == r;
    }
    function isStaff() {
      return signedIn() && request.auth.token.role in
        ['super_admin', 'secretariat_staff', 'data_officer'];
    }
    function isOwnOrg(orgId) {
      return signedIn() && request.auth.token.orgId == orgId;
    }

    // ── Public reference + read-model data (readable by any authenticated member) ──
    // Writes server-only (Admin SDK). Market prices are non-PII, tier-gated at the app
    // layer for history depth; base current-price read is open to signed-in members.
    match /markets/{id}         { allow read: if signedIn(); allow write: if false; }
    match /commodities/{id}     { allow read: if signedIn(); allow write: if false; }
    match /membershipTiers/{id} { allow read: if true;       allow write: if false; }
    match /priceSeriesLatest/{id}  { allow read: if signedIn(); allow write: if false; }
    match /priceSeriesMonthly/{id} { allow read: if signedIn(); allow write: if false; }

    // ── Identity / entitlements ──────────────────────────────────────────────
    match /entitlements/{uid} {
      allow read: if request.auth.uid == uid || isStaff();
      allow write: if false; // minted only by server (setUserRole / standing changes)
    }
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isStaff();
      allow write: if false; // profile edits go through server actions
    }
    match /roles/{id}           { allow read: if isStaff(); allow write: if false; }

    // ── Organisations (org-scoped PII) ───────────────────────────────────────
    match /organisations/{orgId} {
      allow read: if isStaff() || isOwnOrg(orgId);
      allow write: if false; // server-only (create/edit via Admin SDK + audit)
    }

    // ── Money: invoices + payments (server-write-only, org-scoped reads) ──────
    match /invoices/{id} {
      allow read: if isStaff() || isOwnOrg(resource.data.orgId);
      allow write: if false;
    }
    match /payments/{id} {
      allow read: if isStaff() || isOwnOrg(resource.data.orgId);
      allow create, update, delete: if false; // idempotent server writes only (DR-05)
    }

    // ── Field submissions (server state machine; reviewers read) ──────────────
    match /fieldSubmissions/{id} {
      allow read: if isStaff() || request.auth.uid == resource.data.submittedByUid;
      allow write: if false; // submit/decide are callable Functions (SoD enforced server-side)
    }

    // ── Price records + immutable corrections ────────────────────────────────
    match /priceRecords/{id} {
      allow read: if signedIn();
      allow write: if false;
      match /corrections/{cid} {
        allow read: if isStaff();
        allow create, update, delete: if false; // append-only, server-only
      }
    }

    // ── Marketplace: listings readable; deals/escrow client-read-only ─────────
    match /listings/{id} {
      allow read: if signedIn();
      allow write: if false; // createListing / editListing are callable Functions
    }
    match /offers/{id} {
      allow read: if signedIn() &&
        (isStaff() || isOwnOrg(resource.data.offerorOrgId) || isOwnOrg(resource.data.listingOwnerOrgId));
      allow write: if false;
    }
    match /deals/{id} {
      allow read: if isStaff() || isOwnOrg(resource.data.buyerOrgId) || isOwnOrg(resource.data.sellerOrgId);
      allow write: if false; // deal.state transitions only via Cloud Functions (FR-MKTPL-31)
    }
    match /escrow/{id} {
      allow read: if isStaff() || isOwnOrg(resource.data.buyerOrgId) || isOwnOrg(resource.data.sellerOrgId);
      allow create, update, delete: if false; // append-only escrow ledger (FR-MKTPL-41)
    }

    // ── Immutable audit log (H3 / FR-ADM-13, NFR-38) ─────────────────────────
    match /auditLogs/{id} {
      allow read: if hasRole('super_admin') || isStaff();
      allow create, update, delete: if false; // written only via Admin SDK; never mutable
    }

    // ── Immutable consent records (DPA, FR-MEM-46) ───────────────────────────
    match /consents/{uid}/records/{rid} {
      allow read: if request.auth.uid == uid || isStaff();
      allow create, update, delete: if false;
    }

    // ── Deny-by-default (anything not matched above) ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
